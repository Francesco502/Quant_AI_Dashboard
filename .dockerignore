.git/
.gitignore
.gitattributes

# Docker（不嵌套复制）
docker-compose.yml
docker-compose.optimized.yml
.dockerignore

# 文档（镜像不需要）
docs/
*.md
!requirements.txt
*.bat
*.ps1

# 测试（镜像不需要）
tests/
examples/

# 其他
.DS_Store
*.bak
*.tmp
.env
.env.*

# 前端构建产物（由多阶段构建处理，不从宿主机复制）
web/node_modules/
web/.next/
web/out/
