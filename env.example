# ============================================================
# Quant-AI Dashboard example environment
# Copy this file to .env and fill in real values.
# ============================================================

# ------------------------------------------------------------------
# Core security
# ------------------------------------------------------------------
SECRET_KEY=quant-ai-dashboard-secret-key-change-me
# STRICT_SECURITY_VALIDATION=true
TZ=Asia/Shanghai
APP_TIMEZONE=Asia/Shanghai

# ------------------------------------------------------------------
# Login configuration
# Provide either a plain-text password or a password hash.
# ------------------------------------------------------------------
# APP_LOGIN_PASSWORD=change-me
# APP_LOGIN_PASSWORD_HASH=$2b$12$replace-with-bcrypt-hash

# ------------------------------------------------------------------
# Market data providers
# ------------------------------------------------------------------
# ALPHA_VANTAGE_KEY=
# TUSHARE_TOKEN=

# ------------------------------------------------------------------
# LLM / model provider configuration
# The current recommended default is an OpenAI-compatible endpoint.
# ------------------------------------------------------------------
LLM_PROVIDER=openai_compat
ARK_API_KEY=your_volcengine_ark_api_key
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_MODEL=doubao-seed-1-6-thinking

# Optional alternatives
# OPENAI_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-1-6-thinking
# VOLCENGINE_API_KEY=
# VOLCENGINE_ARK_API_KEY=
# VOLCENGINE_BASE_URL=
# VOLCENGINE_MODEL=
# DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=
# DASHSCOPE_MODEL=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama2

# ------------------------------------------------------------------
# Optional analysis extensions
# ------------------------------------------------------------------
# SCRATCHPAD_ENABLED=true
# SCRATCHPAD_DIR=data/scratchpad
# API_RESPONSE_CACHE_ENABLED=true
# API_CACHE_DIR=data/api_cache
# API_CACHE_TTL_PRICES=300
# API_CACHE_TTL_MARKET_REVIEW=600
# API_CACHE_TTL_SECONDS=300
# SKILLS_ENABLED=true
# SKILLS_DIR=core/skills
# SOUL_FILE=path/to/soul.md
# DAILY_ANALYSIS_TICKERS=600519,000858,hk00700,AAPL
# BIAS_THRESHOLD=5.0

# ------------------------------------------------------------------
# Search / news providers
# ------------------------------------------------------------------
# TAVILY_API_KEYS=key1,key2
# SERPAPI_API_KEYS=key1,key2
# BOCHA_API_KEYS=
# BRAVE_API_KEYS=
# NEWS_MAX_AGE_DAYS=3

# ------------------------------------------------------------------
# Notification channels
# ------------------------------------------------------------------
# WECHAT_WEBHOOK_URL=
# FEISHU_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DINGTALK_WEBHOOK_URL=
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=
# PUSHPLUS_TOKEN=

# ------------------------------------------------------------------
# Daemon scheduling
# ------------------------------------------------------------------
# DAILY_ANALYSIS_ENABLED=true
# DAILY_ANALYSIS_TIME=18:00

# ------------------------------------------------------------------
# Browser/API origin policy
# Same-origin is the default release path.
# ------------------------------------------------------------------
API_EXPECT_SAME_ORIGIN=true
# CORS_ORIGINS=https://your-domain.example

# ------------------------------------------------------------------
# SMS alerting (optional)
# ------------------------------------------------------------------
# SMS_PROVIDER=twilio
# SMS_API_KEY=
# SMS_API_SECRET=
# SMS_FROM_NUMBER=+15551234567
# SMS_TO_NUMBERS=+15557654321,+15559876543

# ------------------------------------------------------------------
# Frontend API routing
# For local cross-origin development:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8685/api
#
# For same-origin Docker / reverse-proxy deployment:
# NEXT_PUBLIC_API_URL=/api
