# Quant-AI Dashboard 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ========== 登录密码配置（二选一） ==========
# 方式1：明文密码（简单，适合开发/测试）
# APP_LOGIN_PASSWORD=your_password_here

# 方式2：密码哈希（更安全，推荐用于生产环境）
# 生成哈希：python set_password.py hash your_password
# APP_LOGIN_PASSWORD_HASH=$2b$12$...

# ========== API 密钥（可选） ==========
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# TUSHARE_TOKEN=your_tushare_token

# ========== Streamlit 配置 ==========
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
# STREAMLIT_SERVER_HEADLESS=true

