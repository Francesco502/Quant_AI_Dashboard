# ============================================================
# Quant-AI Dashboard 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ========== JWT 安全密钥（生产环境务必修改！） ==========
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=quant-ai-dashboard-secret-key-change-me
# APP_ENV=development
# 生产发布时建议开启严格安全校验；production 模式下默认会强校验
# STRICT_SECURITY_VALIDATION=true

# ========== 登录密码配置（二选一） ==========
# 方式1：明文密码（简单，适合开发/测试）
# APP_LOGIN_PASSWORD=your_password_here

# 方式2：密码哈希（更安全，推荐用于生产环境）
# 生成方式: python set_password.py hash your_password
# APP_LOGIN_PASSWORD_HASH=$2b$12$...

# ========== API 数据源密钥（可选） ==========
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# TUSHARE_TOKEN=your_tushare_token

# ========== 每日智能分析 / LLM 配置（daily_stock_analysis 移植） ==========
# 至少配置一种 LLM（推荐 OpenAI 兼容或 DeepSeek/通义等）
# 默认使用火山方舟 Ark（OpenAI 格式兼容）
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OPENAI_MODEL=ark-code-latest
# GEMINI_API_KEY=your_gemini_key
# ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# OPENROUTER_API_KEY=your_openrouter_key
# OPENROUTER_MODEL=openai/gpt-3.5-turbo
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama2
# 显式指定 LLM 提供商时可设：LLM_PROVIDER=anthropic|openrouter|ollama

# Scratchpad 分析过程日志（Dexter 借鉴）
# SCRATCHPAD_ENABLED=true
# SCRATCHPAD_DIR=data/scratchpad

# API 响应文件缓存（Dexter 借鉴）
# API_RESPONSE_CACHE_ENABLED=true
# API_CACHE_DIR=data/api_cache
# API_CACHE_TTL_PRICES=300
# API_CACHE_TTL_MARKET_REVIEW=600
# API_CACHE_TTL_SECONDS=300

# Skills 技能目录（Dexter 借鉴）
# SKILLS_ENABLED=true
# SKILLS_DIR=core/skills

# 身份文档（Dexter 借鉴，可选）
# SOUL_FILE=path/to/soul.md

# 自选股（逗号分隔，与 stz 资产池可共存）
# DAILY_ANALYSIS_TICKERS=600519,000858,hk00700,AAPL

# 交易纪律（乖离率阈值，默认 5%）
# BIAS_THRESHOLD=5.0

# 新闻 / 舆情搜索（可选，扩展数据源见 core/search_service 模块说明）
# TAVILY_API_KEYS=key1,key2
# SERPAPI_API_KEYS=key1,key2
# BOCHA_API_KEYS=
# BRAVE_API_KEYS=
# NEWS_MAX_AGE_DAYS=3

# 推送渠道（可选，后续在通知模块中使用）
# WECHAT_WEBHOOK_URL=
# FEISHU_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DINGTALK_WEBHOOK_URL=
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=
# PUSHPLUS_TOKEN=

# 每日分析任务（daemon）
# DAILY_ANALYSIS_ENABLED=true
# DAILY_ANALYSIS_TIME=18:00

# ========== CORS 允许的前端域名 ==========
# 生产环境应设置为实际域名，多个域名用逗号分隔
# CORS_ORIGINS=https://your-domain.com
# 如使用同域反代并且浏览器只访问同一域名，可设置：
API_EXPECT_SAME_ORIGIN=true

# ========== 风险短信告警（可选，支持 Twilio REST API） ==========
# SMS_PROVIDER=twilio
# SMS_API_KEY=your_twilio_account_sid
# SMS_API_SECRET=your_twilio_auth_token
# SMS_FROM_NUMBER=+15551234567
# SMS_TO_NUMBERS=+15557654321,+15559876543

# ========== 前端 API 地址 ==========
# 本地开发（跨域直连后端，需要后端 CORS 允许 8686）
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8685/api
#
# 一体化 Docker 部署 / 同域反代（生产强约束，用户只访问前端端口）
# NEXT_PUBLIC_API_URL=/api
