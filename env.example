# ============================================================
# Quant-AI Dashboard 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ========== JWT 安全密钥（生产环境务必修改！） ==========
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=quant-ai-dashboard-secret-key-change-me

# ========== 登录密码配置（二选一） ==========
# 方式1：明文密码（简单，适合开发/测试）
# APP_LOGIN_PASSWORD=your_password_here

# 方式2：密码哈希（更安全，推荐用于生产环境）
# 生成方式: python set_password.py hash your_password
# APP_LOGIN_PASSWORD_HASH=$2b$12$...

# ========== API 数据源密钥（可选） ==========
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# TUSHARE_TOKEN=your_tushare_token

# ========== CORS 允许的前端域名 ==========
# 生产环境应设置为实际域名，多个域名用逗号分隔
# CORS_ORIGINS=https://your-domain.com

# ========== 前端 API 地址 ==========
# Docker 部署时会自动设置，本地开发时可修改
# NEXT_PUBLIC_API_URL=http://localhost:8685/api
